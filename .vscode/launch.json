  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "[Rust] Debug spiced",
      "program": "${workspaceFolder}/target/debug/spiced",
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "rust: cargo build",
      "env": {
        // "SPICED_LOG" : "debug",
        // "RUST_BACKTRACE": "1"
      },
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "[Rust] Debug Tests",
      "cargo": {
        "args": [
            "test",
            "--no-run",
            "--verbose",
            "nocapture",
            "--package=spiced"
        ],
        "filter": {
            "name": "app_start_test",
            // "kind": "lib"
        }
    },
    "args": [],
    "env": {
      "SPICED_LOG" : "debug",
      // "RUST_BACKTRACE": "1"
    },
    "cwd": "${workspaceFolder}",
    "preLaunchTask": "rust: cargo build",
  },
    {
      "name": "spice version",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/spice/main.go",
      "args": ["version"]
    },
  ]
}
